{
  "name": "disasters-portal",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:ci": "biome ci . && prettier \"**/*.scss\" --check --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write . && prettier \"**/*.scss\" --write --no-error-on-unmatched-pattern",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/dm-mono": "^5.2.7",
    "@tanstack/react-query": "^5.99.0",
    "@teamimpact/veda-ui-blocks": "0.1.0-beta.9",
    "@trussworks/react-uswds": "^11.0.0",
    "@uswds/uswds": "^3.13.0",
    "maplibre-gl": "^5.23.0",
    "next": "16.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-map-gl": "^8.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "lefthook": "^2.1.6",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  }
}
