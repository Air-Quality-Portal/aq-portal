{
  "name": "disasters-portal",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:staged": "biome check",
    "lint:ci": "biome ci .",
    "pretypecheck": "next typegen",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.0",
    "@teamimpact/veda-ui-blocks": "0.1.0-beta.13",
    "@trussworks/react-uswds": "^11.0.0",
    "@uswds/uswds": "^3.13.0",
    "maplibre-gl": "^5.23.0",
    "next": "16.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-map-gl": "^8.1.1"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "lefthook": "^2.1.6",
    "typescript": "5.9.3"
  }
}
